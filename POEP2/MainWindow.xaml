<!-- =========================================================
FILE: MainWindow.xaml
WHATSAPP STYLE GUI
========================================================= -->

<Window x:Class="PART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Violet Vault"
        Height="700"
        Width="450"
        Background="#ECE5DD">

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- =====================================================
             TOP HEADER
        ====================================================== -->
        <Border Grid.Row="0"
                Background="#075E54">

            <TextBlock Text="🔐 Violet Vault"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </Border>

        <!-- =====================================================
             CHAT AREA
        ====================================================== -->
        <ScrollViewer x:Name="ScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="#ECE5DD">

            <StackPanel x:Name="ChatPanel"
                        Margin="10"/>
        </ScrollViewer>

        <!-- =====================================================
             INPUT AREA
        ====================================================== -->
        <Grid Grid.Row="2"
              Background="#F0F0F0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <!-- INPUT BOX -->
            <TextBox x:Name="InputTextBox"
                     Grid.Column="0"
                     Margin="10"
                     Height="45"
                     FontSize="16"
                     VerticalContentAlignment="Center"
                     Padding="10"
                     Background="White"
                     BorderBrush="#CCCCCC"
                     BorderThickness="1"/>

            <!-- SEND BUTTON -->
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Margin="5,10,10,10"
                    Content="Send"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#25D366"
                    Foreground="White"
                    BorderThickness="0"
                    Click="SendButton_Click"/>
        </Grid>

    </Grid>
</Window>